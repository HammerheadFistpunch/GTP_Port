---
import { getCollection, getEntry } from "astro:content";
import BaseLayout from "../../layouts/BaseLayout.astro";
import PortfolioCard from "../../components/portfolio/PortfolioCard.astro";
import Container from "../../components/ui/Container.astro";

const projects = (await getCollection("projects", ({ data }) => !data.draft))
  .sort((a, b) => {
    if (a.data.featured !== b.data.featured) {
      return Number(b.data.featured) - Number(a.data.featured);
    }

    const dateDifference = (b.data.date?.getTime() ?? 0)
      - (a.data.date?.getTime() ?? 0);

    return dateDifference || a.data.title.localeCompare(b.data.title);
  });

const portfolioPage = await getEntry("pages", "portfolio");

if (!portfolioPage || portfolioPage.data.pageType !== "archive") {
  throw new Error("Missing Portfolio page content: src/content/pages/portfolio.md");
}

const page = portfolioPage.data;
---

<BaseLayout
  title={page.title}
  description={page.description}
>
  <section class:list={["archive-hero", `archive-hero--${page.headerStyle}`]}>
    <Container>
      {page.eyebrow && <p class="eyebrow">{page.eyebrow}</p>}
      <h1>{page.headline}</h1>
      <p class="introduction">{page.description}</p>
    </Container>
  </section>

  <section class="archive-list" aria-labelledby="portfolio-projects">
    <Container>
      <h2 id="portfolio-projects">{page.sectionTitle}</h2>

      {projects.length > 0 ? (
        <div class="project-grid">
          {projects.map((project) => (
            <PortfolioCard
              title={project.data.title}
              description={project.data.description}
              image={project.data.coverImage}
              category={project.data.projectType}
              href={`/portfolio/${project.id}/`}
            />
          ))}
        </div>
      ) : (
        <p>{page.emptyMessage}</p>
      )}
    </Container>
  </section>
</BaseLayout>

<style>
  .archive-hero {
    padding: var(--space-lg) 0;
    border-bottom: 1px solid var(--border-color);
  }

  .archive-hero--featured {
    padding: var(--space-xl) 0 var(--space-lg);
  }

  .eyebrow {
    margin-bottom: var(--space-sm);
    color: var(--accent);
    font-family: var(--font-ui);
    font-size: 0.85rem;
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  .archive-hero h1 {
    max-width: 22ch;
    font-size: clamp(2.25rem, 5vw, 3.75rem);
  }

  .archive-hero--featured h1 {
    max-width: 16ch;
    font-size: clamp(3rem, 7vw, 5.5rem);
  }

  .introduction {
    max-width: 44rem;
    font-size: 1.2rem;
  }

  .archive-list {
    padding-top: var(--space-lg);
  }

  .archive-list h2 {
    margin-bottom: var(--space-md);
  }

  .project-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
    gap: var(--space-md);
  }
</style>
