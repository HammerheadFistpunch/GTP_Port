---
import { getEntry, render } from "astro:content";
import StandardPageLayout from "../layouts/StandardPageLayout.astro";
import ContactMethods from "../components/ui/ContactMethods.astro";

const entry = await getEntry("pages", "contact");

if (!entry || entry.data.pageType !== "standard") {
  throw new Error("Missing or invalid Contact content: src/content/pages/contact.md");
}

const { Content } = await render(entry);
---

<StandardPageLayout {...entry.data} links={[]}>
  <ContactMethods links={entry.data.links} />
  <Content />
</StandardPageLayout>
