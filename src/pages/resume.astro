---
import { getEntry, render } from "astro:content";
import StandardPageLayout from "../layouts/StandardPageLayout.astro";
import Timeline from "../components/resume/Timeline.astro";
import ResumeOverview from "../components/resume/ResumeOverview.astro";

const entry = await getEntry("pages", "resume");

if (!entry || entry.data.pageType !== "standard") {
  throw new Error("Missing or invalid Resume content: src/content/pages/resume.md");
}

const { Content } = await render(entry);
---

<StandardPageLayout {...entry.data}>
  <ResumeOverview
    professionalSummary={entry.data.professionalSummary}
    competencies={entry.data.competencies}
  />
  <Timeline items={entry.data.experience} />
  <ResumeOverview education={entry.data.education} />
  <Content />
</StandardPageLayout>
