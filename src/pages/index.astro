---
import { getCollection, getEntry } from "astro:content";
import BaseLayout from "../layouts/BaseLayout.astro";
import Hero from "../components/ui/Hero.astro";
import Container from "../components/ui/Container.astro";
import SectionTitle from "../components/ui/SectionTitle.astro";
import PortfolioCard from "../components/portfolio/PortfolioCard.astro";
import FeaturedArticle from "../components/journal/FeaturedArticle.astro";
import JournalCard from "../components/journal/JournalCard.astro";

const homeEntry = await getEntry("pages", "home");

if (!homeEntry || homeEntry.data.pageType !== "home") {
  throw new Error("Missing or invalid homepage content: src/content/pages/home.md");
}

const page = homeEntry.data;

const allProjects = (await getCollection("entries", ({ data }) =>
  !data.draft && (data.placement === "portfolio" || data.placement === "both")
))
  .sort((a, b) => {
    if (a.data.portfolioOrder !== b.data.portfolioOrder) {
      return a.data.portfolioOrder - b.data.portfolioOrder;
    }

    if (a.data.featured !== b.data.featured) {
      return Number(b.data.featured) - Number(a.data.featured);
    }

    return a.data.title.localeCompare(b.data.title);
  });

const projects = allProjects.slice(0, page.featuredWork.limit);

const allPosts = (await getCollection("entries", ({ data }) =>
  !data.draft && (data.placement === "journal" || data.placement === "both")
))
  .sort((a, b) => {
    if (a.data.featured !== b.data.featured) {
      return Number(b.data.featured) - Number(a.data.featured);
    }

    return (b.data.date?.getTime() ?? 0) - (a.data.date?.getTime() ?? 0);
  });

const articles = allPosts.slice(0, page.journalPreview.limit);
const featuredArticle = articles[0];
const remainingArticles = articles.slice(1);

const dateFormatter = new Intl.DateTimeFormat("en-US", {
  dateStyle: "long",
  timeZone: "UTC",
});
---

<BaseLayout description={page.description} image={page.hero.image}>
  <Hero
    eyebrow={page.hero.eyebrow}
    title={page.hero.title}
    description={page.hero.description}
    image={page.hero.image}
    primaryText={page.hero.primaryCta.label}
    primaryLink={page.hero.primaryCta.href}
    secondaryText={page.hero.secondaryCta.label}
    secondaryLink={page.hero.secondaryCta.href}
  />

  <section>
    <Container>
      <SectionTitle
        title={page.featuredWork.title}
        subtitle={page.featuredWork.subtitle}
        href={page.featuredWork.titleHref}
      />

      {projects.length > 0 ? (
        <div class="project-grid">
          {projects.map((project) => (
            <PortfolioCard
              title={project.data.title}
              description={project.data.description}
              image={project.data.coverImage}
              category={project.data.primaryTopic}
              href={`/archive/${project.id}/`}
            />
          ))}
        </div>
      ) : (
        <p>{page.featuredWork.emptyMessage}</p>
      )}
    </Container>
  </section>

  <section>
    <Container>
      <SectionTitle
        title={page.journalPreview.title}
        subtitle={page.journalPreview.subtitle}
        href={page.journalPreview.titleHref}
      />

      {featuredArticle ? (
        <FeaturedArticle
          title={featuredArticle.data.title}
          excerpt={featuredArticle.data.description}
          image={featuredArticle.data.coverImage}
          category={featuredArticle.data.primaryTopic}
          date={featuredArticle.data.date ? dateFormatter.format(featuredArticle.data.date) : "Date pending"}
          href={`/archive/${featuredArticle.id}/`}
        />
      ) : (
        <p>{page.journalPreview.emptyMessage}</p>
      )}

      {remainingArticles.length > 0 && (
        <div class="journal-list">
          {remainingArticles.map((article) => (
            <JournalCard
              title={article.data.title}
              excerpt={article.data.description}
              image={article.data.coverImage}
              category={article.data.primaryTopic}
              date={article.data.date ? dateFormatter.format(article.data.date) : "Date pending"}
              href={`/archive/${article.id}/`}
            />
          ))}
        </div>
      )}
    </Container>
  </section>

  <section class="about">
    <Container>
      <div class="about-box">
        <h2>{page.aboutCallout.title}</h2>
        <p>{page.aboutCallout.description}</p>
        <a href={page.aboutCallout.link.href}>
          {page.aboutCallout.link.label} →
        </a>
      </div>
    </Container>
  </section>
</BaseLayout>

<style>
  .project-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
    gap: 2rem;
  }

  .journal-list {
    margin-top: 3rem;
  }

  .about {
    padding-bottom: 6rem;
  }

  .about-box {
    padding: 3rem;
    background: var(--bg-surface);
    border: 1px solid var(--border-color);
    border-radius: var(--radius-md);
  }

  .about-box h2 {
    margin-bottom: 1rem;
  }

  .about-box a {
    font-weight: 700;
  }
</style>
