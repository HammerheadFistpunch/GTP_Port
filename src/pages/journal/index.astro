---
import { getCollection, getEntry } from "astro:content";
import BaseLayout from "../../layouts/BaseLayout.astro";
import CategoryNav from "../../components/journal/CategoryNav.astro";
import JournalCard from "../../components/journal/JournalCard.astro";
import Container from "../../components/ui/Container.astro";

const posts = (await getCollection("entries", ({ data }) =>
  !data.draft && (data.placement === "journal" || data.placement === "both")
))
  .sort((a, b) => {
    if (a.data.featured !== b.data.featured) {
      return Number(b.data.featured) - Number(a.data.featured);
    }

    return (b.data.date?.getTime() ?? 0) - (a.data.date?.getTime() ?? 0);
  });

const dateFormatter = new Intl.DateTimeFormat("en-US", {
  dateStyle: "long",
  timeZone: "UTC",
});

const journalPage = await getEntry("pages", "journal");

if (!journalPage || journalPage.data.pageType !== "archive") {
  throw new Error("Missing Journal page content: src/content/pages/journal.md");
}

const page = journalPage.data;
---

<BaseLayout
  title={page.title}
  description={page.description}
>
  <section class:list={["archive-hero", `archive-hero--${page.headerStyle}`]}>
    <Container>
      {page.eyebrow && <p class="eyebrow">{page.eyebrow}</p>}
      <h1>{page.headline}</h1>
      <p class="introduction">{page.description}</p>

      {page.topics.length > 0 && (
        <CategoryNav categories={page.topics} />
      )}
    </Container>
  </section>

  <section class="archive-list" aria-labelledby="journal-entries">
    <Container width="reading">
      <h2 id="journal-entries">{page.sectionTitle}</h2>

      {posts.length > 0 ? (
        posts.map((post) => (
          <JournalCard
            title={post.data.title}
            excerpt={post.data.description}
            image={post.data.coverImage}
            date={post.data.date ? dateFormatter.format(post.data.date) : "Date pending"}
            category={post.data.primaryTopic}
            href={`/archive/${post.id}/`}
          />
        ))
      ) : (
        <p>{page.emptyMessage}</p>
      )}
    </Container>
  </section>
</BaseLayout>

<style>
  .archive-hero {
    padding: var(--space-lg) 0;
    border-bottom: 1px solid var(--border-color);
  }

  .archive-hero--featured {
    padding: var(--space-xl) 0 var(--space-lg);
  }

  .eyebrow {
    margin-bottom: var(--space-sm);
    color: var(--accent);
    font-family: var(--font-ui);
    font-size: 0.85rem;
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  .archive-hero h1 {
    max-width: 22ch;
    font-size: clamp(2.25rem, 5vw, 3.75rem);
  }

  .archive-hero--featured h1 {
    max-width: 15ch;
    font-size: clamp(3rem, 7vw, 5.5rem);
  }

  .introduction {
    max-width: 44rem;
    font-size: 1.2rem;
  }

  .archive-list {
    padding-top: var(--space-lg);
  }

  .archive-list h2 {
    margin-bottom: var(--space-md);
  }
</style>
