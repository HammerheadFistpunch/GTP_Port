---
import {
  getCollection,
  render,
  type CollectionEntry,
} from "astro:content";
import JournalLayout from "../../layouts/JournalLayout.astro";

export async function getStaticPaths() {
  const posts = await getCollection("journal");

  const publishedPosts = posts.filter((post) => !post.data.draft);

  return publishedPosts.map((post) => {
    const relatedArticles = publishedPosts
      .filter((candidate) => candidate.id !== post.id)
      .map((candidate) => ({
        candidate,
        score:
          (candidate.data.category === post.data.category ? 3 : 0) +
          candidate.data.tags.filter((tag) => post.data.tags.includes(tag)).length,
      }))
      .sort((a, b) =>
        b.score - a.score ||
        b.candidate.data.date.getTime() - a.candidate.data.date.getTime()
      )
      .slice(0, 3)
      .map(({ candidate }) => ({
        title: candidate.data.title,
        excerpt: candidate.data.description,
        image: candidate.data.coverImage,
        date: candidate.data.date.toLocaleDateString("en-US", {
          year: "numeric",
          month: "short",
          day: "numeric",
          timeZone: "UTC",
        }),
        category: candidate.data.category,
        href: `/journal/${candidate.id}/`,
      }));

    return {
      params: { slug: post.id },
      props: { post, relatedArticles },
    };
  });
}

interface Props {
  post: CollectionEntry<"journal">;
  relatedArticles: Array<{
    title: string;
    excerpt: string;
    image?: string;
    date: string;
    category: string;
    href: string;
  }>;
}

const { post, relatedArticles } = Astro.props;
const { Content } = await render(post);
---

<JournalLayout {...post.data} {relatedArticles}>
  <Content />
</JournalLayout>
