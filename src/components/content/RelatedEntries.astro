---
import PortfolioCard from "../portfolio/PortfolioCard.astro";

interface RelatedEntry {
  title: string;
  description: string;
  image?: string;
  primaryTopic: string;
  href: string;
}

interface Props {
  entries: RelatedEntry[];
  title?: string;
}

const { entries, title = "Related entries" } = Astro.props;
---

{entries.length > 0 && (
  <aside class="related" aria-labelledby="related-entries-heading">
    <h2 id="related-entries-heading">{title}</h2>

    <div class="entry-grid">
      {entries.map((entry) => (
        <PortfolioCard
          title={entry.title}
          description={entry.description}
          image={entry.image}
          category={entry.primaryTopic}
          href={entry.href}
        />
      ))}
    </div>
  </aside>
)}

<style>
  .related {
    margin-top: var(--space-lg);
    padding-top: var(--space-lg);
    border-top: 1px solid var(--border-color);
  }

  .related h2 {
    margin-bottom: var(--space-md);
  }

  .entry-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(min(260px, 100%), 1fr));
    gap: var(--space-md);
  }
</style>
