---
interface GalleryImage {
  src: string;
  alt: string;
  caption?: string;
}

interface Props {
  id: string;
  images: GalleryImage[];
}

const { id, images } = Astro.props;
---

<div class="lightbox" data-lightbox-root>
  <div class="thumbnail-grid">
    {images.map((image, index) => (
      <button
        type="button"
        class="thumbnail"
        data-lightbox-open
        data-index={index}
        data-src={image.src}
        data-alt={image.alt}
        data-caption={image.caption}
        aria-label={`Open image ${index + 1}: ${image.alt}`}
        aria-haspopup="dialog"
      >
        <img src={image.src} alt={image.alt} loading="lazy" decoding="async" />
      </button>
    ))}
  </div>

  <dialog class="lightbox-dialog" data-lightbox-dialog aria-labelledby={`${id}-title`}>
    <div class="dialog-toolbar">
      <p id={`${id}-title`}>Image viewer</p>
      <button type="button" class="close" data-lightbox-close aria-label="Close image viewer">
        &times;
      </button>
    </div>

    <div class="active-image">
      <button type="button" class="previous" data-lightbox-previous aria-label="Previous image">
        &lsaquo;
      </button>
      <img data-lightbox-image alt="" />
      <button type="button" class="next" data-lightbox-next aria-label="Next image">
        &rsaquo;
      </button>
    </div>

    <p class="caption" data-lightbox-caption></p>
  </dialog>
</div>

<script>
  function setupLightbox(root: Element) {
    const dialog = root.querySelector("[data-lightbox-dialog]");
    const image = root.querySelector("[data-lightbox-image]");
    const caption = root.querySelector("[data-lightbox-caption]");
    const triggers = [...root.querySelectorAll<HTMLElement>("[data-lightbox-open]")];
    const closeButton = root.querySelector("[data-lightbox-close]");
    const previousButton = root.querySelector("[data-lightbox-previous]");
    const nextButton = root.querySelector("[data-lightbox-next]");

    if (!(dialog instanceof HTMLDialogElement) || !(image instanceof HTMLImageElement)) return;

    let activeIndex = 0;
    let returnFocus: HTMLElement | null = null;

    const showImage = (index: number) => {
      activeIndex = (index + triggers.length) % triggers.length;
      const trigger = triggers[activeIndex];
      image.src = trigger.dataset.src ?? "";
      image.alt = trigger.dataset.alt ?? "";

      if (caption instanceof HTMLElement) {
        caption.textContent = trigger.dataset.caption ?? "";
        caption.hidden = !caption.textContent;
      }
    };

    triggers.forEach((trigger, index) => {
      trigger.addEventListener("click", () => {
        returnFocus = trigger;
        showImage(index);
        dialog.showModal();
      });
    });

    closeButton?.addEventListener("click", () => dialog.close());
    previousButton?.addEventListener("click", () => showImage(activeIndex - 1));
    nextButton?.addEventListener("click", () => showImage(activeIndex + 1));

    dialog.addEventListener("click", (event) => {
      if (event.target === dialog) dialog.close();
    });

    dialog.addEventListener("close", () => returnFocus?.focus());
  }

  document.querySelectorAll("[data-lightbox-root]").forEach(setupLightbox);
</script>

<style>
  .thumbnail-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(min(220px, 100%), 1fr));
    gap: var(--space-sm);
  }

  .thumbnail {
    overflow: hidden;
    padding: 0;
    background: var(--bg-surface);
    border: 1px solid var(--border-color);
    border-radius: var(--radius-md);
    cursor: zoom-in;
  }

  .thumbnail img {
    width: 100%;
    aspect-ratio: 4 / 3;
    object-fit: cover;
    transition: transform 0.2s ease;
  }

  .thumbnail:hover img {
    transform: scale(1.025);
  }

  .lightbox-dialog {
    width: min(94vw, 1200px);
    max-width: none;
    padding: var(--space-sm);
    background: var(--bg-primary);
    border: 1px solid var(--border-color);
    border-radius: var(--radius-md);
    color: var(--text-primary);
  }

  .lightbox-dialog::backdrop {
    background: rgba(0, 0, 0, 0.88);
  }

  .dialog-toolbar {
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: var(--space-sm);
    margin-bottom: var(--space-sm);
  }

  .dialog-toolbar p,
  .caption {
    margin: 0;
  }

  .close,
  .previous,
  .next {
    display: grid;
    place-items: center;
    width: 2.75rem;
    height: 2.75rem;
    background: var(--bg-elevated);
    border: 1px solid var(--border-color);
    border-radius: 999px;
    color: var(--text-primary);
    cursor: pointer;
    font-size: 1.75rem;
  }

  .active-image {
    display: grid;
    grid-template-columns: auto minmax(0, 1fr) auto;
    align-items: center;
    gap: var(--space-sm);
  }

  .active-image img {
    width: 100%;
    max-height: 78vh;
    object-fit: contain;
  }

  .caption {
    padding-top: var(--space-sm);
    color: var(--text-secondary);
    text-align: center;
  }

  @media (max-width: 640px) {
    .active-image {
      grid-template-columns: 1fr 1fr;
    }

    .active-image img {
      grid-column: 1 / -1;
      grid-row: 1;
    }

    .previous,
    .next {
      justify-self: center;
    }
  }
</style>
