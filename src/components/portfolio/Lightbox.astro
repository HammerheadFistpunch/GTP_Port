---
interface GalleryImage {
  src: string;
  alt: string;
  caption?: string;
}

interface Props {
  id: string;
  images: GalleryImage[];
}

const { id, images } = Astro.props;
const closeTarget = `${id}-heading`;
---

<div class="lightbox">
  <div class="thumbnail-grid">
    {images.map((image, index) => (
      <a
        class="thumbnail"
        href={`#${id}-image-${index + 1}`}
        aria-label={`Open image ${index + 1}: ${image.alt}`}
      >
        <img src={image.src} alt={image.alt} loading="lazy" decoding="async" />
      </a>
    ))}
  </div>

  {images.map((image, index) => {
    const previousIndex = (index - 1 + images.length) % images.length;
    const nextIndex = (index + 1) % images.length;

    return (
      <div
        id={`${id}-image-${index + 1}`}
        class="lightbox-overlay"
        role="dialog"
        aria-modal="true"
        aria-label={`Image ${index + 1} of ${images.length}: ${image.alt}`}
      >
        <a class="backdrop" href={`#${closeTarget}`} aria-label="Close image viewer"></a>

        <div class="lightbox-panel">
          <div class="dialog-toolbar">
            <p>Image {index + 1} of {images.length}</p>
            <a class="control close" href={`#${closeTarget}`} aria-label="Close image viewer">
              &times;
            </a>
          </div>

          <div class="active-image">
            {images.length > 1 && (
              <a
                class="control previous"
                href={`#${id}-image-${previousIndex + 1}`}
                aria-label="Previous image"
              >
                &lsaquo;
              </a>
            )}

            <img src={image.src} alt={image.alt} />

            {images.length > 1 && (
              <a
                class="control next"
                href={`#${id}-image-${nextIndex + 1}`}
                aria-label="Next image"
              >
                &rsaquo;
              </a>
            )}
          </div>

          {image.caption && <p class="caption">{image.caption}</p>}
        </div>
      </div>
    );
  })}
</div>

<style>
  .thumbnail-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(min(220px, 100%), 1fr));
    gap: var(--space-sm);
  }

  .thumbnail {
    display: block;
    overflow: hidden;
    background: var(--bg-surface);
    border: 1px solid var(--border-color);
    border-radius: var(--radius-md);
    cursor: zoom-in;
  }

  .thumbnail img {
    width: 100%;
    aspect-ratio: 4 / 3;
    object-fit: cover;
    transition: transform 0.2s ease;
  }

  .thumbnail:hover img,
  .thumbnail:focus-visible img {
    transform: scale(1.025);
  }

  .lightbox-overlay {
    position: fixed;
    z-index: 1000;
    inset: 0;
    display: none;
    place-items: center;
    padding: var(--space-sm);
  }

  .lightbox-overlay:target {
    display: grid;
  }

  .backdrop {
    position: absolute;
    inset: 0;
    background: rgba(0, 0, 0, 0.88);
    cursor: zoom-out;
  }

  .lightbox-panel {
    position: relative;
    z-index: 1;
    width: min(94vw, 1200px);
    max-height: 94vh;
    overflow: auto;
    padding: var(--space-sm);
    background: var(--bg-primary);
    border: 1px solid var(--border-color);
    border-radius: var(--radius-md);
    color: var(--text-primary);
  }

  .dialog-toolbar {
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: var(--space-sm);
    margin-bottom: var(--space-sm);
  }

  .dialog-toolbar p,
  .caption {
    margin: 0;
  }

  .control {
    display: grid;
    place-items: center;
    width: 2.75rem;
    height: 2.75rem;
    flex: 0 0 auto;
    background: var(--bg-elevated);
    border: 1px solid var(--border-color);
    border-radius: 999px;
    color: var(--text-primary);
    font-size: 1.75rem;
    line-height: 1;
    text-decoration: none;
  }

  .active-image {
    display: grid;
    grid-template-columns: auto minmax(0, 1fr) auto;
    align-items: center;
    gap: var(--space-sm);
  }

  .active-image img {
    width: 100%;
    max-height: 78vh;
    object-fit: contain;
  }

  .caption {
    padding-top: var(--space-sm);
    color: var(--text-secondary);
    text-align: center;
  }

  @media (max-width: 640px) {
    .active-image {
      grid-template-columns: 1fr 1fr;
    }

    .active-image img {
      grid-column: 1 / -1;
      grid-row: 1;
    }

    .previous,
    .next {
      justify-self: center;
    }
  }
</style>
