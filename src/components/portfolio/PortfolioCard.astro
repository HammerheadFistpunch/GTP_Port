---
interface Props {
  title: string;
  description: string;
  image?: string;
  category: string;
  href: string;
}

const {
  title,
  description,
  image,
  category,
  href,
} = Astro.props;
---

<a class="card" href={href}>
  {image ? (
    <img src={image} alt={title} loading="lazy" />
  ) : (
    <div class="image-placeholder" aria-hidden="true">
      <span>{category}</span>
    </div>
  )}

  <div class="content">
    <span class="category">{category}</span>

    <h3>{title}</h3>

    <p>{description}</p>
  </div>
</a>

<style>
.card {
  display: block;
  overflow: hidden;

  background: var(--bg-surface);
  border: 1px solid var(--border-color);
  border-radius: var(--radius-md);

  color: inherit;
  text-decoration: none;

  transition:
    transform .25s ease,
    box-shadow .25s ease;
}

.card:hover {
  transform: translateY(-4px);
  box-shadow: var(--shadow-soft);
}

.card img {
  width: 100%;
  aspect-ratio: 16 / 9;
  object-fit: cover;
}

.image-placeholder {
  display: grid;
  place-items: center;

  width: 100%;
  aspect-ratio: 16 / 9;

  background: var(--bg-elevated);
  color: var(--accent);

  font-family: var(--font-ui);
  font-size: .8rem;
  font-weight: 700;
  letter-spacing: .08em;
  text-transform: uppercase;
}

.content {
  padding: 1.5rem;
}

.category {
  display: inline-block;

  margin-bottom: .75rem;

  color: var(--accent);

  font-size: .8rem;
  font-weight: 700;
  letter-spacing: .08em;
  text-transform: uppercase;
}

.content h3 {
  margin-bottom: .75rem;
}

.content p {
  margin: 0;
}
</style>
