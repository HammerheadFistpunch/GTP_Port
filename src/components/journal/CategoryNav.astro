---
const categories = [

"Technology",

"Cars",

"Photography",

"Projects",

"Personal"

];
---

<div class="categories" aria-label="Journal topics">

{categories.map(category => (

<span>

{category}

</span>

))}

</div>

<style>

.categories{

display:flex;

gap:1rem;

flex-wrap:wrap;

margin-bottom:3rem;

}

.categories span{

padding:.5rem 1rem;

border-radius:999px;

background:var(--bg-surface);

border:1px solid var(--border-color);

color:var(--text-secondary);

}

</style>
