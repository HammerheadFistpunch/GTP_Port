---
interface Props {
  category: string;
  date: Date;
  updatedDate?: Date;
  tags?: string[];
}

const {
  category,
  date,
  updatedDate,
  tags = [],
} = Astro.props;

const dateFormatter = new Intl.DateTimeFormat("en-US", {
  dateStyle: "long",
  timeZone: "UTC",
});
---

<div class="article-meta" aria-label="Article information">
  <span class="category">{category}</span>

  <span aria-hidden="true">•</span>

  <time datetime={date.toISOString()}>
    {dateFormatter.format(date)}
  </time>

  {updatedDate && (
    <span class="updated">
      Updated <time datetime={updatedDate.toISOString()}>
        {dateFormatter.format(updatedDate)}
      </time>
    </span>
  )}

  {tags.length > 0 && (
    <ul class="tags" aria-label="Article tags">
      {tags.map((tag) => <li>{tag}</li>)}
    </ul>
  )}
</div>

<style>
  .article-meta {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 0.5rem;
    margin-bottom: var(--space-sm);
    color: var(--text-secondary);
    font-family: var(--font-ui);
    font-size: 0.85rem;
    letter-spacing: 0.06em;
    text-transform: uppercase;
  }

  .category {
    color: var(--accent);
    font-weight: 700;
  }

  .updated {
    flex-basis: 100%;
  }

  .tags {
    display: flex;
    flex-basis: 100%;
    flex-wrap: wrap;
    gap: 0.5rem;
    margin: 0.5rem 0 0;
    padding: 0;
    list-style: none;
  }

  .tags li {
    margin: 0;
    padding: 0.25rem 0.6rem;
    background: var(--bg-surface);
    border: 1px solid var(--border-color);
    border-radius: 999px;
    color: var(--text-secondary);
    font-size: 0.75rem;
  }
</style>
