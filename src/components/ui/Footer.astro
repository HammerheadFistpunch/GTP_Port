---
import { getEntry } from "astro:content";

const siteEntry = await getEntry("settings", "site");

if (!siteEntry) {
    throw new Error("Missing site settings: src/content/settings/site.md");
}

const site = siteEntry.data;
---

<footer class="site-footer">

    <div class="footer-inner">

        <div>

            <h3>{site.footerTitle}</h3>

            <p>{site.footerDescription}</p>

        </div>

        <nav>

            {site.footerLinks.map((item) => (
                <a href={item.href}>{item.label}</a>
            ))}

        </nav>

    </div>

    <div class="copyright">

        © {new Date().getFullYear()} {site.copyrightName}

    </div>

</footer>

<style>

.site-footer {

    border-top: 1px solid var(--border-color);

    margin-top: var(--space-xl);

    padding: 4rem 2rem;

    background: var(--bg-surface);

}

.footer-inner {

    max-width: var(--content-width);

    margin: auto;

    display: flex;

    justify-content: space-between;

    gap: 4rem;

}

.footer-inner nav {

    display: flex;

    flex-direction: column;

    gap: .75rem;

}

.footer-inner a {

    color: var(--text-secondary);

}

.footer-inner a:hover {

    color: var(--accent);

}

.copyright {

    margin-top: 3rem;

    text-align: center;

    color: var(--text-secondary);

    font-size: .9rem;

}

@media (max-width:768px){

.footer-inner{

flex-direction:column;

}

}

</style>
