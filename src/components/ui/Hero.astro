---
import Container from "./Container.astro";
import Button from "./Button.astro";

interface Props {

  title: string;

  description: string;

  eyebrow?: string;

  image?: string;

  primaryText?: string;
  primaryLink?: string;

  secondaryText?: string;
  secondaryLink?: string;

}

const {

  title,

  description,

  eyebrow,

  image,

  primaryText,
  primaryLink,

  secondaryText,
  secondaryLink

} = Astro.props;
---

<section class="hero">

  <Container>

    <div class="hero-grid">

      <div class="hero-copy">

        {eyebrow && <p class="eyebrow">{eyebrow}</p>}

        <h1>{title}</h1>

        <p>{description}</p>

        {(primaryText && primaryLink) || (secondaryText && secondaryLink) ? (
          <div class="buttons">

            {primaryText && primaryLink && (
              <Button href={primaryLink}>
                {primaryText}
              </Button>
            )}

            {secondaryText && secondaryLink && (
              <Button
                href={secondaryLink}
                variant="secondary">

                {secondaryText}

              </Button>
            )}

          </div>
        ) : null}

      </div>

      {image && (

        <div class="hero-image">

          <img
            src={image}
            alt={title}
          />

        </div>

      )}

    </div>

  </Container>

</section>

<style>

.hero {

  padding: 7rem 0;

}

.hero-grid {

  display: grid;

  grid-template-columns: 1.2fr 1fr;

  gap: 5rem;

  align-items: center;

}

.hero-copy h1 {

  margin-bottom: 1rem;

}

.eyebrow {

  margin-bottom: var(--space-sm);

  color: var(--accent);

  font-family: var(--font-ui);

  font-size: .85rem;

  font-weight: 700;

  letter-spacing: .08em;

  text-transform: uppercase;

}

.hero-copy p {

  font-size: 1.2rem;

  margin-bottom: 2rem;

}

.buttons {

  display: flex;

  gap: 1rem;

  flex-wrap: wrap;

}

.hero-image img {

  width: 100%;

  border-radius: var(--radius-md);

  box-shadow: var(--shadow-soft);

}

@media (max-width: 900px) {

.hero-grid {

grid-template-columns: 1fr;

}

}

</style>
