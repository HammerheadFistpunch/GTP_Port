---
interface Props {
  title: string;
  subtitle?: string;
}

const { title, subtitle } = Astro.props;
---

<div class="section-title">

  <h2>{title}</h2>

  {subtitle && <p>{subtitle}</p>}

</div>

<style>

.section-title {

  margin-bottom: 3rem;

}

.section-title h2 {

  margin-bottom: .5rem;

}

.section-title p {

  max-width: 700px;

  color: var(--text-secondary);

  font-size: 1.1rem;

}

</style>