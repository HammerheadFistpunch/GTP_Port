---
interface Props {
  title: string;
  subtitle?: string;
  href?: string;
}

const { title, subtitle, href } = Astro.props;
---

<div class="section-title">

  <h2>
    {href ? <a href={href}>{title}</a> : title}
  </h2>

  {subtitle && <p>{subtitle}</p>}

</div>

<style>

.section-title {

  margin-bottom: 3rem;

}

.section-title h2 {

  margin-bottom: .5rem;

}

.section-title h2 a {

  color: inherit;
  text-decoration: none;

}

.section-title h2 a:hover,
.section-title h2 a:focus-visible {

  color: var(--accent);

}

.section-title p {

  max-width: 700px;

  color: var(--text-secondary);

  font-size: 1.1rem;

}

</style>
