---
import { getEntry } from "astro:content";

const siteEntry = await getEntry("settings", "site");

if (!siteEntry) {
  throw new Error("Missing site settings: src/content/settings/site.md");
}

const site = siteEntry.data;

const normalizePath = (path: string) => {
  if (path === "/") return path;
  return path.replace(/\/$/, "");
};

const currentPath = normalizePath(Astro.url.pathname);

const isCurrentPage = (href: string) => {
  const itemPath = normalizePath(href);

  if (itemPath === "/") {
    return currentPath === "/";
  }

  return currentPath === itemPath || currentPath.startsWith(`${itemPath}/`);
};
---

<nav class="site-nav" aria-label="Primary navigation">
  <div class="nav-container">

    <a href="/" class="logo" aria-current={currentPath === "/" ? "page" : undefined}>
      {site.logoText}
    </a>

    <button
      class="nav-toggle"
      type="button"
      aria-expanded="false"
      aria-controls="primary-nav-links"
    >
      <span class="nav-toggle-label">Menu</span>
      <span class="nav-toggle-icon" aria-hidden="true">
        <span></span>
        <span></span>
        <span></span>
      </span>
    </button>

    <ul class="nav-links" id="primary-nav-links">
      {site.navigation.map((item) => (
        <li>
          <a
            href={item.href}
            aria-current={isCurrentPage(item.href) ? "page" : undefined}
          >
            {item.label}
          </a>
        </li>
      ))}
    </ul>

  </div>
</nav>

<script>
  document.documentElement.classList.add("js");

  const navigation = document.querySelector<HTMLElement>(".site-nav");
  const toggle = navigation?.querySelector<HTMLButtonElement>(".nav-toggle");
  const toggleLabel = toggle?.querySelector<HTMLElement>(".nav-toggle-label");
  const menuLinks = navigation?.querySelectorAll<HTMLAnchorElement>(".nav-links a");

  const setMenuState = (isOpen: boolean, returnFocus = false) => {
    if (!navigation || !toggle || !toggleLabel) return;

    navigation.toggleAttribute("data-menu-open", isOpen);
    toggle.setAttribute("aria-expanded", String(isOpen));
    toggleLabel.textContent = isOpen ? "Close" : "Menu";

    if (returnFocus) toggle.focus();
  };

  toggle?.addEventListener("click", () => {
    const isOpen = toggle.getAttribute("aria-expanded") === "true";
    setMenuState(!isOpen);
  });

  menuLinks?.forEach((link) => {
    link.addEventListener("click", () => setMenuState(false));
  });

  document.addEventListener("keydown", (event) => {
    if (event.key === "Escape" && navigation?.hasAttribute("data-menu-open")) {
      setMenuState(false, true);
    }
  });

  document.addEventListener("click", (event) => {
    if (
      navigation?.hasAttribute("data-menu-open") &&
      event.target instanceof Node &&
      !navigation.contains(event.target)
    ) {
      setMenuState(false);
    }
  });

  window.matchMedia("(min-width: 769px)").addEventListener("change", (event) => {
    if (event.matches) setMenuState(false);
  });
</script>

<style>
.site-nav {
  position: sticky;
  top: 0;
  z-index: 1000;

  background: var(--bg-primary);
  border-bottom: 1px solid rgba(255,255,255,.08);

  backdrop-filter: blur(10px);
}

.nav-container {
  max-width: 1200px;
  margin: 0 auto;

  display: flex;
  justify-content: space-between;
  align-items: center;

  padding: 1rem 2rem;
}

.logo {
  font-family: var(--font-ui);
  font-size: 1.2rem;
  font-weight: 700;

  color: var(--text-primary);
  text-decoration: none;
  letter-spacing: .03em;
}

.nav-toggle {
  display: none;
  align-items: center;
  gap: .65rem;
  min-height: 44px;
  padding: .5rem .75rem;
  border: 1px solid var(--border-color);
  border-radius: var(--radius-sm);
  background: var(--bg-surface);
  color: var(--text-primary);
  font: inherit;
  font-weight: 700;
  cursor: pointer;
}

.nav-toggle-icon {
  display: grid;
  gap: 4px;
  width: 20px;
}

.nav-toggle-icon span {
  display: block;
  width: 100%;
  height: 2px;
  border-radius: 2px;
  background: currentColor;
  transition: transform .2s ease, opacity .2s ease;
}

.site-nav[data-menu-open] .nav-toggle-icon span:nth-child(1) {
  transform: translateY(6px) rotate(45deg);
}

.site-nav[data-menu-open] .nav-toggle-icon span:nth-child(2) {
  opacity: 0;
}

.site-nav[data-menu-open] .nav-toggle-icon span:nth-child(3) {
  transform: translateY(-6px) rotate(-45deg);
}

.nav-links {
  display: flex;
  gap: 2rem;

  list-style: none;

  margin: 0;
  padding: 0;
}

.nav-links a {
  color: var(--text-secondary);

  text-decoration: none;

  font-family: var(--font-ui);
  font-size: .95rem;
  font-weight: 500;

  transition: color .2s ease;
}

.nav-links a:hover {
  color: var(--accent);
}

.nav-links a[aria-current="page"] {
  color: var(--text-primary);
  text-decoration: underline;
  text-decoration-color: var(--accent);
  text-decoration-thickness: 2px;
  text-underline-offset: .45rem;
}

@media (max-width: 768px) {
  .nav-container {
    position: relative;
    flex-wrap: wrap;
    padding: .75rem 1rem;
  }

  .logo {
    min-width: 0;
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
  }

  :global(.js) .nav-toggle {
    display: inline-flex;
  }

  .nav-links {
    width: 100%;
    flex-direction: column;
    gap: 0;
    padding-top: .75rem;
    border-top: 1px solid var(--border-color);
  }

  :global(.js) .nav-links {
    position: absolute;
    top: 100%;
    right: 0;
    left: 0;
    display: none;
    padding: .5rem 1rem 1rem;
    border-top: 1px solid var(--border-color);
    background: var(--bg-primary);
    box-shadow: var(--shadow-soft);
  }

  :global(.js) .site-nav[data-menu-open] .nav-links {
    display: flex;
  }

  .nav-links a {
    display: block;
    min-height: 44px;
    padding: .75rem 0;
  }

  .nav-links a[aria-current="page"] {
    text-underline-offset: .3rem;
  }
}
</style>
