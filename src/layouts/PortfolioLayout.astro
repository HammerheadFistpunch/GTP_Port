---
import BaseLayout from "./BaseLayout.astro";
import ProjectMeta from "../components/portfolio/ProjectMeta.astro";
import Container from "../components/ui/Container.astro";

interface ProjectLinks {
  repository?: string;
  demo?: string;
  external?: string;
}

interface Props {
  title: string;
  description: string;
  projectType: string;
  date?: Date;
  tags?: string[];
  technologies?: string[];
  links?: ProjectLinks;
  coverImage?: string;
}

const {
  title,
  description,
  projectType,
  date,
  tags = [],
  technologies = [],
  links,
  coverImage,
} = Astro.props;

const projectLinks = [
  links?.demo && { label: "View Project", href: links.demo },
  links?.repository && { label: "View Repository", href: links.repository },
  links?.external && { label: "Visit Website", href: links.external },
].filter(Boolean) as { label: string; href: string }[];
---

<BaseLayout
  title={title}
  description={description}
>
  <article class="project-entry" aria-labelledby="entry-title">
    <Container width="reading">
      <a class="back-link" href="/portfolio">← Back to Corpus</a>

      <header class="entry-header">
        <ProjectMeta
          {projectType}
          {date}
          {technologies}
          {tags}
        />

        <h1 id="entry-title">{title}</h1>
        <p class="entry-description">{description}</p>

        {projectLinks.length > 0 && (
          <nav class="project-links" aria-label="Project links">
            {projectLinks.map((link) => (
              <a href={link.href}>{link.label} →</a>
            ))}
          </nav>
        )}
      </header>

      {coverImage && (
        <figure class="entry-hero">
          <img src={coverImage} alt={title} />
        </figure>
      )}

      <div class="project-content">
        <slot />
      </div>
    </Container>
  </article>
</BaseLayout>

<style>
  .project-entry {
    padding: var(--space-lg) 0 var(--space-xl);
  }

  .back-link {
    display: inline-block;
    margin-bottom: var(--space-lg);
    font-family: var(--font-ui);
    font-weight: 700;
  }

  .entry-header {
    margin-bottom: var(--space-lg);
    padding: var(--space-md);
    background: var(--bg-surface);
    border: 1px solid var(--border-color);
    border-radius: var(--radius-md);
  }

  .entry-description {
    max-width: 42rem;
    font-size: 1.15rem;
  }

  .project-links {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-sm);
    margin-top: var(--space-md);
  }

  .project-links a {
    font-weight: 700;
  }

  .entry-hero {
    margin: 0 0 var(--space-lg);
  }

  .entry-hero img {
    width: 100%;
    border-radius: var(--radius-md);
    box-shadow: var(--shadow-soft);
  }

  .project-content {
    font-family: var(--font-editorial);
  }
</style>
