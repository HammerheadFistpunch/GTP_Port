---
import BaseLayout from "./BaseLayout.astro";
import ProjectMeta from "../components/portfolio/ProjectMeta.astro";
import Gallery from "../components/portfolio/Gallery.astro";
import ImmichGallery from "../components/portfolio/ImmichGallery.astro";
import VideoEmbed from "../components/portfolio/VideoEmbed.astro";
import InlineImageLightbox from "../components/portfolio/InlineImageLightbox.astro";
import RelatedProjects from "../components/portfolio/RelatedProjects.astro";
import Container from "../components/ui/Container.astro";

interface ProjectLinks {
  repository?: string;
  demo?: string;
  external?: string;
}

interface Props {
  title: string;
  description: string;
  projectType: string;
  date?: Date;
  tags?: string[];
  technologies?: string[];
  links?: ProjectLinks;
  coverImage?: string;
  media?: ProjectMedia[];
  immichGallery?: {
    shareUrl: string;
    title?: string;
    imageAltPrefix?: string;
  };
  relatedProjects?: Array<{
    title: string;
    description: string;
    image?: string;
    category: string;
    href: string;
  }>;
}

interface ProjectMedia {
  type: "image" | "video";
  src: string;
  alt?: string;
  caption?: string;
}

const {
  title,
  description,
  projectType,
  date,
  tags = [],
  technologies = [],
  links,
  coverImage,
  media = [],
  immichGallery,
  relatedProjects = [],
} = Astro.props;

const galleryImages = media
  .filter((item) => item.type === "image")
  .map((item) => ({
    src: item.src,
    alt: item.alt || title,
    caption: item.caption,
  }));

const videos = media.filter((item) => item.type === "video");

const projectLinks = [
  links?.demo && { label: "View Project", href: links.demo },
  links?.repository && { label: "View Repository", href: links.repository },
  links?.external && { label: "Visit Website", href: links.external },
].filter(Boolean) as { label: string; href: string }[];
---

<BaseLayout
  title={title}
  description={description}
  image={coverImage}
  type="article"
>
  <article class="project-entry" aria-labelledby="entry-title">
    <Container width="reading">
      <a class="back-link" href="/portfolio">← Back to Corpus</a>

      <header class="entry-header">
        <ProjectMeta
          {projectType}
          {date}
          {technologies}
          {tags}
        />

        <h1 id="entry-title">{title}</h1>
        <p class="entry-description">{description}</p>

        {projectLinks.length > 0 && (
          <nav class="project-links" aria-label="Project links">
            {projectLinks.map((link) => (
              <a href={link.href}>{link.label} →</a>
            ))}
          </nav>
        )}
      </header>

      {coverImage && (
        <figure class="entry-hero">
          <img src={coverImage} alt={title} />
        </figure>
      )}

      <div class="project-content">
        <slot />
      </div>

      <InlineImageLightbox />

      <Gallery id="project-gallery" images={galleryImages} />

      {immichGallery && (
        <ImmichGallery
          shareUrl={immichGallery.shareUrl}
          title={immichGallery.title}
          imageAltPrefix={immichGallery.imageAltPrefix}
        />
      )}

      {videos.length > 0 && (
        <section class="project-videos" aria-labelledby="project-videos-heading">
          <h2 id="project-videos-heading">Project videos</h2>
          <div class="video-list">
            {videos.map((video, index) => (
              <VideoEmbed
                src={video.src}
                title={video.alt || `${title} video ${index + 1}`}
                caption={video.caption}
              />
            ))}
          </div>
        </section>
      )}

      <RelatedProjects projects={relatedProjects} />
    </Container>
  </article>
</BaseLayout>

<style>
  .project-entry {
    padding: var(--space-lg) 0 var(--space-xl);
  }

  .back-link {
    display: inline-block;
    margin-bottom: var(--space-lg);
    font-family: var(--font-ui);
    font-weight: 700;
  }

  .entry-header {
    margin-bottom: var(--space-lg);
    padding: var(--space-md);
    background: var(--bg-surface);
    border: 1px solid var(--border-color);
    border-radius: var(--radius-md);
  }

  .entry-description {
    max-width: 42rem;
    font-size: 1.15rem;
  }

  .project-links {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-sm);
    margin-top: var(--space-md);
  }

  .project-links a {
    font-weight: 700;
  }

  .entry-hero {
    margin: 0 0 var(--space-lg);
  }

  .entry-hero img {
    width: 100%;
    border-radius: var(--radius-md);
    box-shadow: var(--shadow-soft);
  }

  .project-content {
    font-family: var(--font-editorial);
  }

  .project-videos {
    padding: var(--space-lg) 0 0;
  }

  .project-videos h2 {
    margin-bottom: var(--space-md);
  }

  .video-list {
    display: grid;
    gap: var(--space-md);
  }
</style>
