---
import BaseLayout from "./BaseLayout.astro";
import ArticleMeta from "../components/journal/ArticleMeta.astro";
import RelatedArticles from "../components/journal/RelatedArticles.astro";
import ImmichGallery from "../components/portfolio/ImmichGallery.astro";
import Container from "../components/ui/Container.astro";

interface Props {
  title: string;
  description: string;
  date: Date;
  updatedDate?: Date;
  category: string;
  tags?: string[];
  coverImage?: string;
  immichGallery?: {
    shareUrl: string;
    title?: string;
    imageAltPrefix?: string;
  };
  relatedArticles?: Array<{
    title: string;
    excerpt: string;
    image?: string;
    date: string;
    category: string;
    href: string;
  }>;
}

const {
  title,
  description,
  date,
  updatedDate,
  category,
  tags = [],
  coverImage,
  immichGallery,
  relatedArticles = [],
} = Astro.props;
---

<BaseLayout
  title={title}
  description={description}
  image={coverImage}
  type="article"
>
  <article class="journal-entry" aria-labelledby="entry-title">
    <Container width="reading">
      <a class="back-link" href="/journal">← Back to Journal</a>

      <header class="entry-header">
        <ArticleMeta
          {category}
          {date}
          {updatedDate}
          {tags}
        />

        <h1 id="entry-title">{title}</h1>
        <p class="entry-description">{description}</p>
      </header>

      {coverImage && (
        <figure class="entry-hero">
          <img src={coverImage} alt={title} />
        </figure>
      )}

      <div class="article-content">
        <slot />
      </div>

      {immichGallery && (
        <ImmichGallery
          shareUrl={immichGallery.shareUrl}
          title={immichGallery.title}
          imageAltPrefix={immichGallery.imageAltPrefix}
        />
      )}

      <RelatedArticles articles={relatedArticles} />
    </Container>
  </article>
</BaseLayout>

<style>
  .journal-entry {
    padding: var(--space-lg) 0 var(--space-xl);
  }

  .back-link {
    display: inline-block;
    margin-bottom: var(--space-lg);
    font-family: var(--font-ui);
    font-weight: 700;
  }

  .entry-header {
    margin-bottom: var(--space-lg);
    padding-bottom: var(--space-md);
    border-bottom: 1px solid var(--border-color);
  }

  .entry-description {
    max-width: 42rem;
    margin-bottom: 0;
    font-family: var(--font-editorial);
    font-size: 1.25rem;
  }

  .entry-hero {
    margin: 0 0 var(--space-lg);
  }

  .entry-hero img {
    width: 100%;
    border-radius: var(--radius-md);
    box-shadow: var(--shadow-soft);
  }
</style>
