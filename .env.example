# Public TinaCloud project identifier. Safe to expose to the browser.
TINA_PUBLIC_CLIENT_ID=bce22d76-7099-40c4-9574-e69b5555a914

# Read-only content token from the TinaCloud project dashboard.
# Keep the real value in .env locally and in Cloudflare Pages environment variables.
TINA_TOKEN=replace-with-your-read-only-token

# TinaCloud edits and production builds target this branch.
GITHUB_BRANCH=gpt-handoff
